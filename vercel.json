{
  "services": {
    "frontend": {
      "root": "mern-auth/client",
      "framework": "vite"
    },
    "backend": {
      "root": "mern-auth/server",
      "entrypoint": "server.js"
    }
  },
  "rewrites": [
    {
      "source": "/api(/.*)?",
      "destination": {
        "type": "service",
        "service": "backend"
      }
    },
    {
      "source": "/(login|email-verify|reset-password|dashboard)",
      "destination": "/index.html"
    },
    {
      "source": "/(.*)",
      "destination": {
        "type": "service",
        "service": "frontend"
      }
    }
  ]
}
